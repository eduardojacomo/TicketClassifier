# Copie para .env e ajuste.
# Processamento em lote
TAMANHO_LOTE=20        # tickets por chamada ao LLM
LOTES_PARALELOS=3      # chamadas simultâneas
LOTE_UNICO=false       # true = tudo em UMA chamada (ignora TAMANHO_LOTE)

# Provedor de IA: "mock" (heurística local, sem chave), "anthropic" ou "gemini".
LLM_PROVIDER=mock

# Anthropic (Claude) — necessário se LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Google Gemini — necessário se LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
